---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { monthlyTiers, oneTimeTiers, impactExamples, site } from '../../data/config';
---

<BaseLayout
  title="Donate"
  description="Support the Earthing Institute's mission to advance peer-reviewed research on grounding and human health. Your tax-deductible donation funds the next breakthrough study."
  hideDonateBar={true}
>
  <!-- Hero with urgency -->
  <section class="bg-green-primary py-16 lg:py-24 relative overflow-hidden">
    <div class="absolute inset-0 opacity-5">
      <svg class="w-full h-full" preserveAspectRatio="none">
        <pattern id="donate-dots" width="30" height="30" patternUnits="userSpaceOnUse">
          <circle cx="15" cy="15" r="1.5" fill="white" />
        </pattern>
        <rect width="100%" height="100%" fill="url(#donate-dots)" />
      </svg>
    </div>
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="inline-flex items-center gap-2 px-3 py-1 bg-white/10 rounded-full mb-6">
        <span class="w-2 h-2 bg-white rounded-full animate-pulse"></span>
        <span class="text-sm font-medium text-white/90">501(c)(3) Tax-Deductible</span>
      </div>

      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-heading font-bold text-white mb-6 leading-[1.1]">
        Fund the Science<br />That Changes Lives
      </h1>
      <p class="text-lg lg:text-xl text-white/80 max-w-2xl mx-auto mb-10 leading-relaxed">
        For less than the cost of a coffee each month, you can help fund
        peer-reviewed research that is changing how the world understands health.
      </p>

      <!-- Progress bar -->
      <div class="max-w-lg mx-auto">
        <div class="flex justify-between text-sm text-white/70 mb-2">
          <span class="font-semibold text-white">$4,000 raised</span>
          <span>$10,000 goal</span>
        </div>
        <div class="w-full h-4 bg-white/20 rounded-full overflow-hidden">
          <div class="h-full bg-white rounded-full transition-all duration-1000 relative" style="width: 40%">
            <div class="absolute inset-0 rounded-full bg-gradient-to-r from-transparent via-white/30 to-transparent animate-pulse"></div>
          </div>
        </div>
        <p class="text-sm text-white/60 mt-3">Every dollar directly funds peer-reviewed research</p>
      </div>
    </div>
  </section>

  <!-- Impact Calculator -->
  <section class="py-16 lg:py-20 bg-white border-b border-cream-dark">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <h2 class="text-2xl lg:text-3xl font-heading font-bold text-green-primary mb-3">
          See Your Impact
        </h2>
        <p class="text-slate">Choose an amount to see what your donation makes possible.</p>
      </div>

      <div class="flex flex-wrap justify-center gap-3 mb-8" id="impact-buttons">
        {impactExamples.map((item, i) => (
          <button
            class:list={[
              'impact-btn px-5 py-2.5 rounded-full text-sm font-semibold transition-all border-2',
              i === 2
                ? 'bg-green-primary text-white border-green-primary'
                : 'bg-white text-slate-dark border-cream-dark hover:border-green-primary hover:text-green-primary',
            ]}
            data-amount={item.amount}
            data-impact={item.impact}
          >
            ${item.amount}
          </button>
        ))}
      </div>

      <div class="bg-green-light/50 rounded-2xl p-8 text-center border border-green-primary/10">
        <p class="text-green-dark text-lg font-medium" id="impact-text">
          {impactExamples[2].impact}
        </p>
        <a
          href="#monthly"
          id="impact-donate-btn"
          class="inline-flex items-center mt-4 px-6 py-3 bg-green-primary text-white font-semibold rounded-full hover:bg-green-dark transition-colors"
        >
          Donate $<span id="impact-btn-amount">{impactExamples[2].amount}</span>
          <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path d="M19 14l-7 7m0 0l-7-7m7 7V3" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Monthly Giving — PRIMARY -->
  <section id="monthly" class="py-16 lg:py-24 bg-gradient-to-b from-cream to-green-light/20">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 bg-green-primary/10 rounded-full mb-4">
          <svg class="w-4 h-4 text-green-primary" viewBox="0 0 20 20" fill="currentColor">
            <path d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z" />
          </svg>
          <span class="text-sm font-bold text-green-primary">Recommended</span>
        </div>
        <h2 class="text-3xl lg:text-4xl font-heading font-bold text-green-primary mb-4">
          Give Monthly, Change Everything
        </h2>
        <p class="text-lg text-slate max-w-2xl mx-auto">
          Monthly donors are the backbone of our research. A small recurring gift provides the
          <strong>stable funding</strong> we need to plan and execute long-term studies.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {monthlyTiers.map((tier) => (
          <div
            class:list={[
              'relative rounded-2xl p-6 transition-all hover:-translate-y-1 hover:shadow-lg border',
              'featured' in tier && tier.featured
                ? 'bg-white ring-2 ring-green-primary shadow-md border-green-primary'
                : 'bg-white border-cream-dark shadow-sm',
            ]}
          >
            {'featured' in tier && tier.featured && (
              <div class="absolute -top-3 left-1/2 -translate-x-1/2">
                <span class="inline-flex items-center px-3 py-1 bg-green-primary text-white text-xs font-bold rounded-full">
                  Most Popular
                </span>
              </div>
            )}

            <div class="text-sm font-semibold text-slate-light uppercase tracking-wide mb-1">
              {tier.name}
            </div>
            <div class="flex items-baseline gap-1 mb-1">
              <span class="text-3xl font-heading font-bold text-green-primary">${tier.amount}</span>
              <span class="text-sm text-slate-light">/month</span>
            </div>
            <p class="text-xs text-green-dark font-medium mb-4 italic">{tier.tagline}</p>

            <ul class="space-y-2 mb-6">
              {tier.benefits.map((benefit) => (
                <li class="flex items-start gap-2">
                  <svg class="w-4 h-4 text-green-primary shrink-0 mt-0.5" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                  </svg>
                  <span class="text-xs text-slate">{benefit}</span>
                </li>
              ))}
            </ul>

            <a
              href={tier.stripeLink === '#' ? '#' : tier.stripeLink}
              class:list={[
                'block w-full text-center px-4 py-2.5 text-sm font-semibold rounded-full transition-colors',
                'featured' in tier && tier.featured
                  ? 'bg-green-primary text-white hover:bg-green-dark shadow-md'
                  : 'bg-green-primary/10 text-green-primary hover:bg-green-primary hover:text-white',
              ]}
            >
              Give ${tier.amount}/mo
            </a>
          </div>
        ))}
      </div>

      <p class="text-center text-sm text-slate-light mt-6">
        Cancel or change your monthly gift anytime. No commitment required.
      </p>
    </div>
  </section>

  <!-- One-Time Giving — SECONDARY -->
  <section id="one-time" class="py-16 lg:py-20 bg-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <h2 class="text-2xl lg:text-3xl font-heading font-bold text-green-primary mb-3">
          Prefer a One-Time Gift?
        </h2>
        <p class="text-slate max-w-xl mx-auto">
          Every amount helps. Choose a one-time donation below.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {oneTimeTiers.map((tier) => (
          <div
            class:list={[
              'relative rounded-2xl p-6 transition-all hover:-translate-y-1 hover:shadow-lg border',
              'featured' in tier && tier.featured
                ? 'bg-cream ring-2 ring-green-primary shadow-md border-green-primary'
                : 'bg-cream border-cream-dark shadow-sm',
            ]}
          >
            {'featured' in tier && tier.featured && (
              <div class="absolute -top-3 left-1/2 -translate-x-1/2">
                <span class="inline-flex items-center px-3 py-1 bg-green-primary text-white text-xs font-bold rounded-full">
                  Best Value
                </span>
              </div>
            )}

            <div class="text-sm font-semibold text-slate-light uppercase tracking-wide mb-1">
              {tier.name}
            </div>
            <div class="text-3xl font-heading font-bold text-green-primary mb-4">
              ${tier.amount}
            </div>

            <ul class="space-y-2 mb-6">
              {tier.benefits.map((benefit) => (
                <li class="flex items-start gap-2">
                  <svg class="w-4 h-4 text-green-primary shrink-0 mt-0.5" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                  </svg>
                  <span class="text-xs text-slate">{benefit}</span>
                </li>
              ))}
            </ul>

            <a
              href={tier.stripeLink === '#' ? '#' : tier.stripeLink}
              class:list={[
                'block w-full text-center px-4 py-2.5 text-sm font-semibold rounded-full transition-colors',
                'featured' in tier && tier.featured
                  ? 'bg-green-primary text-white hover:bg-green-dark shadow-md'
                  : 'bg-green-primary/10 text-green-primary hover:bg-green-primary hover:text-white',
              ]}
            >
              Donate ${tier.amount}
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Major Giving -->
  <section class="py-12 bg-cream border-y border-cream-dark">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h3 class="text-xl font-heading font-bold text-green-primary mb-3">Major Gifts & Study Sponsorship</h3>
      <p class="text-slate mb-4">
        Interested in sponsoring a study ($1,000+), funding a pilot trial ($5,000+),
        or sponsoring a full randomized controlled trial ($20,000+)?
      </p>
      <a href={`mailto:${site.email}`} class="inline-flex items-center text-green-primary font-semibold hover:underline">
        Contact us at {site.email}
        <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
        </svg>
      </a>
    </div>
  </section>

  <!-- Donor Wall -->
  <section class="py-16 lg:py-20 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-heading font-bold text-green-primary mb-4">
          Thank You to Our Supporters
        </h2>
        <p class="text-slate">
          These generous individuals and organizations make our research possible.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="text-center p-6 bg-amber-50 rounded-2xl border border-amber-200">
          <div class="text-2xl mb-2">&#9733;</div>
          <h3 class="font-heading font-bold text-amber-800 mb-1">Gold</h3>
          <p class="text-sm text-amber-700">Wags 2 Whiskers</p>
        </div>

        <div class="text-center p-6 bg-gray-50 rounded-2xl border border-gray-200">
          <div class="text-2xl mb-2">&#9733;</div>
          <h3 class="font-heading font-bold text-gray-600 mb-1">Silver</h3>
          <p class="text-sm text-gray-500">Earthing Revolution</p>
        </div>

        <div class="text-center p-6 bg-orange-50 rounded-2xl border border-orange-200 lg:col-span-2">
          <div class="text-2xl mb-2">&#9733;</div>
          <h3 class="font-heading font-bold text-orange-800 mb-3">Bronze</h3>
          <div class="flex flex-wrap justify-center gap-x-4 gap-y-1">
            <span class="text-sm text-orange-700">MA Luisa Lopez</span>
            <span class="text-sm text-orange-700">Nancy Koehler</span>
            <span class="text-sm text-orange-700">Eve Silver</span>
            <span class="text-sm text-orange-700">Dale Jackson</span>
            <span class="text-sm text-orange-700">Anna Marinelli</span>
            <span class="text-sm text-orange-700">Carla Preyer</span>
            <span class="text-sm text-orange-700">Derrick Storey</span>
          </div>
        </div>
      </div>

      <div class="text-center mt-10">
        <p class="text-slate text-sm mb-2">Want to see your name here?</p>
        <a href="#monthly" class="inline-flex items-center text-green-primary font-semibold hover:underline">
          Join our supporters
          <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path d="M5 10l7-7m0 0l7 7m-7-7v18" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Tax Info -->
  <section class="py-12 bg-cream-dark">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-sm text-slate">
        The Earthing Institute is a 501(c)(3) nonprofit organization.
        All donations are tax-deductible to the extent allowed by law.
        For questions about donations, contact us at
        <a href={`mailto:${site.email}`} class="text-green-primary hover:underline">{site.email}</a>.
      </p>
    </div>
  </section>
</BaseLayout>

<script>
  // Impact calculator
  const buttons = document.querySelectorAll('.impact-btn');
  const impactText = document.getElementById('impact-text');
  const impactBtnAmount = document.getElementById('impact-btn-amount');

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      buttons.forEach(b => {
        b.classList.remove('bg-green-primary', 'text-white', 'border-green-primary');
        b.classList.add('bg-white', 'text-slate-dark', 'border-cream-dark');
      });
      btn.classList.add('bg-green-primary', 'text-white', 'border-green-primary');
      btn.classList.remove('bg-white', 'text-slate-dark', 'border-cream-dark');
      const el = btn as HTMLElement;
      if (impactText) impactText.textContent = el.dataset.impact || '';
      if (impactBtnAmount) impactBtnAmount.textContent = el.dataset.amount || '';
    });
  });
</script>
