---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/sections/Hero.astro';
import ImpactStats from '../components/sections/ImpactStats.astro';
import MissionPreview from '../components/sections/MissionPreview.astro';
import ResearchPreview from '../components/sections/ResearchPreview.astro';
import FundraisingCTA from '../components/sections/FundraisingCTA.astro';
import TestimonialCarousel from '../components/sections/TestimonialCarousel.astro';
import WhatIsEarthing from '../components/sections/WhatIsEarthing.astro';
