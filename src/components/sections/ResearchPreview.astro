---
import { featuredStudies } from '../../data/config';

const topicColors: Record<string, string> = {
  'Inflammation': 'bg-red-50 text-red-700 border-red-200',
  'Sleep': 'bg-indigo-50 text-indigo-700 border-indigo-200',
  'Blood': 'bg-rose-50 text-rose-700 border-rose-200',
  'Pain': 'bg-orange-50 text-orange-700 border-orange-200',
  'Recovery': 'bg-teal-50 text-teal-700 border-teal-200',
};
---

<section class="py-20 lg:py-28 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-12">
      <div>
        <h2 class="text-3xl lg:text-4xl font-heading font-bold text-green-primary mb-4">
          The Science Speaks
        </h2>
        <p class="text-lg text-slate max-w-2xl">
          Over two decades of peer-reviewed research has explored how earthing affects inflammation,
          blood flow, sleep, pain, and recovery.
        </p>
      </div>
      <a
        href="/research"
        class="inline-flex items-center px-6 py-3 bg-green-primary/10 text-green-primary font-semibold rounded-full hover:bg-green-primary/20 transition-colors shrink-0"
      >
        View all 35+ studies
        <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>

    <div class="grid md:grid-cols-3 gap-6">
      {featuredStudies.map((study) => (
        <article class="bg-cream rounded-2xl p-6 lg:p-8 border border-cream-dark hover:shadow-md transition-shadow group">
          <div class="flex items-center gap-3 mb-4">
            <span class:list={['inline-flex px-2.5 py-0.5 text-xs font-semibold rounded-full border', topicColors[study.topic] || 'bg-gray-50 text-gray-700 border-gray-200']}>
              {study.topic}
            </span>
            <span class="text-sm text-slate-light">{study.year}</span>
          </div>

          <h3 class="text-lg font-heading font-bold text-slate-dark mb-3 group-hover:text-green-primary transition-colors leading-snug">
            {study.title}
          </h3>

          <p class="text-sm text-slate-light italic mb-4">{study.journal}</p>

          <p class="text-sm text-slate leading-relaxed">
            {study.finding}
          </p>
        </article>
      ))}
    </div>
  </div>
</section>
