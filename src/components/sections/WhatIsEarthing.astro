---
---

<section class="py-20 lg:py-28 bg-cream">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
      <!-- Content -->
      <div>
        <h2 class="text-3xl lg:text-4xl font-heading font-bold text-green-primary mb-6">
          What is Earthing?
        </h2>
        <p class="text-lg text-slate leading-relaxed mb-6">
          Earthing, also known as grounding, is the practice of making direct physical
          contact with the Earth's surface. Walking barefoot on grass, soil, or sand
          connects your body to the Earth's natural electric charge.
        </p>
        <p class="text-lg text-slate leading-relaxed mb-6">
          Research shows this connection transfers free electrons from the Earth into the body,
          reducing inflammation, improving sleep, decreasing pain, and normalizing the body's
          biological rhythms.
        </p>

        <div class="grid sm:grid-cols-2 gap-4 mb-8">
          <div class="flex items-start gap-3">
            <div class="w-8 h-8 rounded-lg bg-green-light flex items-center justify-center shrink-0 mt-0.5">
              <svg class="w-4 h-4 text-green-primary" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
            </div>
            <div>
              <h4 class="font-semibold text-slate-dark text-sm">Reduced Inflammation</h4>
              <p class="text-sm text-slate-light">Neutralizes free radicals through electron transfer</p>
            </div>
          </div>
          <div class="flex items-start gap-3">
            <div class="w-8 h-8 rounded-lg bg-green-light flex items-center justify-center shrink-0 mt-0.5">
              <svg class="w-4 h-4 text-green-primary" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
            </div>
            <div>
              <h4 class="font-semibold text-slate-dark text-sm">Better Sleep</h4>
              <p class="text-sm text-slate-light">Normalizes cortisol rhythms for deeper rest</p>
            </div>
          </div>
          <div class="flex items-start gap-3">
            <div class="w-8 h-8 rounded-lg bg-green-light flex items-center justify-center shrink-0 mt-0.5">
              <svg class="w-4 h-4 text-green-primary" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
            </div>
            <div>
              <h4 class="font-semibold text-slate-dark text-sm">Pain Relief</h4>
              <p class="text-sm text-slate-light">Documented reduction in chronic pain conditions</p>
            </div>
          </div>
          <div class="flex items-start gap-3">
            <div class="w-8 h-8 rounded-lg bg-green-light flex items-center justify-center shrink-0 mt-0.5">
              <svg class="w-4 h-4 text-green-primary" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
            </div>
            <div>
              <h4 class="font-semibold text-slate-dark text-sm">Faster Recovery</h4>
              <p class="text-sm text-slate-light">Accelerates healing from exercise and injury</p>
            </div>
          </div>
        </div>

        <a
          href="/basics"
          class="inline-flex items-center px-6 py-3 bg-green-primary text-white font-semibold rounded-full hover:bg-green-dark transition-colors"
        >
          Learn How to Get Started
          <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>

      <!-- Visual -->
      <div class="relative">
        <div class="aspect-square rounded-3xl overflow-hidden bg-gradient-to-br from-green-light via-cream to-cream-dark border border-cream-dark">
          <div class="absolute inset-0 flex items-center justify-center">
            <div class="text-center p-8">
              <svg viewBox="0 0 200 200" class="w-48 h-48 mx-auto text-green-primary/20">
                <!-- Stylized feet on earth -->
                <circle cx="100" cy="100" r="90" fill="none" stroke="currentColor" stroke-width="1.5" />
                <ellipse cx="100" cy="140" rx="70" ry="20" fill="currentColor" opacity="0.1" />
                <path d="M80 90c0-15 8-30 20-40 12 10 20 25 20 40s-8 25-20 30c-12-5-20-15-20-30z" fill="currentColor" opacity="0.15" />
                <!-- Ground line -->
                <path d="M20 140h160" stroke="currentColor" stroke-width="1" stroke-dasharray="4 4" />
                <!-- Electron dots -->
                <circle cx="60" cy="145" r="3" fill="currentColor" opacity="0.3">
                  <animate attributeName="cy" values="145;130;145" dur="2s" repeatCount="indefinite" />
                </circle>
                <circle cx="100" cy="145" r="3" fill="currentColor" opacity="0.3">
                  <animate attributeName="cy" values="145;125;145" dur="2.5s" repeatCount="indefinite" />
                </circle>
                <circle cx="140" cy="145" r="3" fill="currentColor" opacity="0.3">
                  <animate attributeName="cy" values="145;128;145" dur="1.8s" repeatCount="indefinite" />
                </circle>
              </svg>
              <p class="text-green-primary/40 text-sm font-medium mt-4">Image: Earthing illustration</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
