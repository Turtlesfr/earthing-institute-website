---
---

<section class="py-20 lg:py-28 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 class="text-3xl lg:text-4xl font-heading font-bold text-green-primary mb-4">
        Discover Earthing
      </h2>
      <p class="text-lg text-slate">
        Watch the documentary that has reached over 5.9 million people worldwide.
      </p>
    </div>

    <div class="grid lg:grid-cols-2 gap-8 lg:gap-12 items-center">
      <!-- Movie -->
      <div class="bg-cream rounded-2xl overflow-hidden border border-cream-dark">
        <div class="aspect-video bg-gradient-to-br from-slate-dark to-green-dark flex items-center justify-center relative group cursor-pointer">
          <div class="absolute inset-0 bg-black/20 group-hover:bg-black/10 transition-colors"></div>
          <div class="relative z-10 w-20 h-20 rounded-full bg-white/90 flex items-center justify-center shadow-xl group-hover:scale-110 transition-transform">
            <svg class="w-8 h-8 text-green-primary ml-1" viewBox="0 0 24 24" fill="currentColor">
              <path d="M8 5v14l11-7z" />
            </svg>
          </div>
          <div class="absolute bottom-4 left-4 right-4 z-10">
            <div class="text-white font-heading font-bold text-lg">The Earthing Movie</div>
            <div class="text-white/70 text-sm">The Remarkable Science of Grounding</div>
          </div>
        </div>
        <div class="p-6">
          <p class="text-slate text-sm leading-relaxed">
            This award-winning documentary explores the scientific research behind
            earthing and features interviews with leading researchers, doctors, and
            people whose health has been transformed.
          </p>
          <a
            href="https://www.youtube.com/watch?v=44ddtR0XDVU"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center mt-4 text-green-primary font-semibold text-sm hover:underline"
          >
            Watch free on YouTube
            <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
          </a>
        </div>
      </div>

      <!-- Book -->
      <div class="bg-cream rounded-2xl overflow-hidden border border-cream-dark">
        <div class="p-8 lg:p-10">
          <div class="flex items-start gap-6">
            <div class="w-32 h-44 bg-gradient-to-br from-green-dark to-green-primary rounded-lg shadow-lg shrink-0 flex items-center justify-center">
              <div class="text-center text-white p-3">
                <div class="font-heading font-bold text-sm leading-tight">EARTHING</div>
                <div class="text-[10px] mt-1 opacity-70">The Most Important Health Discovery Ever?</div>
              </div>
            </div>
            <div>
              <h3 class="text-xl font-heading font-bold text-green-primary mb-2">The Earthing Book</h3>
              <p class="text-sm text-slate-light italic mb-3">
                By Clint Ober, Dr. Stephen Sinatra & Martin Zucker
              </p>
              <p class="text-slate text-sm leading-relaxed mb-4">
                Published in 17 languages, this groundbreaking book presents the science
                and stories behind the most important health discovery in decades.
              </p>
              <a
                href="https://www.amazon.com/Earthing-Important-Health-Discovery-Ever/dp/1591203740"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center text-green-primary font-semibold text-sm hover:underline"
              >
                Get the book
                <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
