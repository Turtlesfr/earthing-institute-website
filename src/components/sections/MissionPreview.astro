---
---

<section class="py-20 lg:py-28">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="max-w-3xl mx-auto text-center mb-16">
      <h2 class="text-3xl lg:text-4xl font-heading font-bold text-green-primary mb-6">
        Our Mission
      </h2>
      <p class="text-lg lg:text-xl text-slate leading-relaxed">
        The Earthing Institute is a nonprofit research and education organization focused on
        understanding how direct physical connection with the Earth influences inflammation,
        nervous system regulation, and human health.
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-8">
      <!-- Research -->
      <div class="bg-white rounded-2xl p-8 shadow-sm hover:shadow-md transition-shadow border border-cream-dark">
        <div class="w-14 h-14 rounded-xl bg-green-light flex items-center justify-center mb-5">
          <svg class="w-7 h-7 text-green-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M9 3h6M12 3v3M7.5 9.5a4.5 4.5 0 109 0 4.5 4.5 0 00-9 0zM12 14v4M5 21h14M8 18h8" />
          </svg>
        </div>
        <h3 class="text-xl font-heading font-bold text-green-primary mb-3">Rigorous Research</h3>
        <p class="text-slate leading-relaxed">
          We advance peer-reviewed research exploring grounding as a low-cost,
          non-invasive intervention with measurable physiological effects on the human body.
        </p>
        <a href={`${import.meta.env.BASE_URL}research`} class="inline-flex items-center mt-4 text-green-primary font-semibold text-sm hover:underline">
          View 35+ studies
          <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>

      <!-- Education -->
      <div class="bg-white rounded-2xl p-8 shadow-sm hover:shadow-md transition-shadow border border-cream-dark">
        <div class="w-14 h-14 rounded-xl bg-green-light flex items-center justify-center mb-5">
          <svg class="w-7 h-7 text-green-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M12 14l9-5-9-5-9 5 9 5zM12 14l6.16-3.42A12.08 12.08 0 0121 17.5M12 14l-6.16-3.42A12.08 12.08 0 003 17.5M12 14v7" />
          </svg>
        </div>
        <h3 class="text-xl font-heading font-bold text-green-primary mb-3">Global Education</h3>
        <p class="text-slate leading-relaxed">
          We curate credible scientific findings and responsibly educate the public
          and health professionals worldwide through courses, publications, and media.
        </p>
        <a href={`${import.meta.env.BASE_URL}courses`} class="inline-flex items-center mt-4 text-green-primary font-semibold text-sm hover:underline">
          Explore courses
          <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>

      <!-- Advocacy -->
      <div class="bg-white rounded-2xl p-8 shadow-sm hover:shadow-md transition-shadow border border-cream-dark">
        <div class="w-14 h-14 rounded-xl bg-green-light flex items-center justify-center mb-5">
          <svg class="w-7 h-7 text-green-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z" />
          </svg>
        </div>
        <h3 class="text-xl font-heading font-bold text-green-primary mb-3">Health Advocacy</h3>
        <p class="text-slate leading-relaxed">
          We envision a world where every person knows that earthing is as essential
          for health as good nutrition, sleep, exercise, and a positive mindset.
        </p>
        <a href={`${import.meta.env.BASE_URL}mission`} class="inline-flex items-center mt-4 text-green-primary font-semibold text-sm hover:underline">
          Read our vision
          <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>
