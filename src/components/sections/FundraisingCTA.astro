---
import { monthlyTiers } from '../../data/config';
---

<section class="py-20 lg:py-28 bg-green-primary relative overflow-hidden">
  <!-- Background pattern -->
  <div class="absolute inset-0 opacity-5">
    <svg class="w-full h-full" preserveAspectRatio="none">
      <pattern id="grid" width="40" height="40" patternUnits="userSpaceOnUse">
        <circle cx="20" cy="20" r="1.5" fill="white" />
      </pattern>
      <rect width="100%" height="100%" fill="url(#grid)" />
    </svg>
  </div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="max-w-3xl mx-auto text-center mb-14">
      <h2 class="text-3xl lg:text-4xl font-heading font-bold text-white mb-6">
        This Research Needs You
      </h2>
      <p class="text-lg text-white/80 leading-relaxed">
        As a 501(c)(3) nonprofit, every breakthrough depends on the generosity of people
        who believe in the science. A small monthly gift provides the stable funding
        we need to plan and execute long-term studies.
      </p>

      <!-- Progress bar -->
      <div class="mt-8 max-w-md mx-auto">
        <div class="flex justify-between text-sm text-white/70 mb-2">
          <span>$4,000 raised</span>
          <span>$10,000 goal</span>
        </div>
        <div class="w-full h-3 bg-white/20 rounded-full overflow-hidden">
          <div class="h-full bg-white rounded-full transition-all duration-1000" style="width: 40%"></div>
        </div>
        <p class="text-sm text-white/60 mt-2">Help us reach our goal to fund the next study</p>
      </div>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 lg:gap-6">
      {monthlyTiers.map((tier) => (
        <a
          href="/donate"
          class:list={[
            'block rounded-2xl p-6 transition-all hover:-translate-y-1 hover:shadow-xl group',
            'featured' in tier && tier.featured
              ? 'bg-white text-slate-dark ring-2 ring-white shadow-lg'
              : 'bg-white/10 text-white hover:bg-white/20 border border-white/20',
          ]}
        >
          {'featured' in tier && tier.featured && (
            <div class="inline-flex items-center px-2.5 py-0.5 bg-green-primary text-white text-xs font-bold rounded-full mb-3">
              Most Popular
            </div>
          )}
          <div class="text-sm font-medium opacity-70 mb-1">{tier.name}</div>
          <div class="flex items-baseline gap-1 mb-1">
            <span class:list={[
              'text-3xl font-heading font-bold',
              'featured' in tier && tier.featured ? 'text-green-primary' : '',
            ]}>
              ${tier.amount}
            </span>
            <span class:list={[
              'text-sm',
              'featured' in tier && tier.featured ? 'text-slate-light' : 'opacity-60',
            ]}>/mo</span>
          </div>
          <p class:list={[
            'text-xs italic mb-4',
            'featured' in tier && tier.featured ? 'text-green-dark' : 'opacity-60',
          ]}>{tier.tagline}</p>
          <ul class="space-y-2">
            {tier.benefits.slice(0, 2).map((benefit) => (
              <li class="flex items-start gap-2 text-sm">
                <svg class:list={['w-4 h-4 mt-0.5 shrink-0', 'featured' in tier && tier.featured ? 'text-green-primary' : 'text-white/60']} viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
                <span class="opacity-80">{benefit}</span>
              </li>
            ))}
          </ul>
        </a>
      ))}
    </div>

    <div class="text-center mt-10">
      <a
        href="/donate"
        class="inline-flex items-center px-8 py-3.5 bg-white text-green-primary font-semibold rounded-full hover:bg-white/90 transition-all shadow-lg hover:shadow-xl hover:-translate-y-0.5"
      >
        View All Giving Options
        <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </div>
</section>
