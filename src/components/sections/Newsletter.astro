---
---

<section class="py-20 lg:py-24 bg-cream-dark">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <div class="w-16 h-16 rounded-2xl bg-green-light flex items-center justify-center mx-auto mb-6">
      <svg class="w-8 h-8 text-green-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
      </svg>
    </div>
    <h2 class="text-3xl lg:text-4xl font-heading font-bold text-green-primary mb-4">
      Stay Grounded in the Science
    </h2>
    <p class="text-lg text-slate mb-8">
      Join our mailing list for research updates, new studies, and earthing news.
      No spam — just science.
    </p>
    <form class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto">
      <input
        type="text"
        name="first_name"
        placeholder="First name"
        required
        class="flex-1 px-5 py-3 bg-white border border-cream-dark rounded-full text-slate-dark placeholder-slate-light focus:outline-none focus:border-green-primary focus:ring-2 focus:ring-green-primary/20 transition-all"
      />
      <input
        type="email"
        name="email"
        placeholder="Email address"
        required
        class="flex-1 px-5 py-3 bg-white border border-cream-dark rounded-full text-slate-dark placeholder-slate-light focus:outline-none focus:border-green-primary focus:ring-2 focus:ring-green-primary/20 transition-all"
      />
      <button
        type="submit"
        class="px-8 py-3 bg-green-primary text-white font-semibold rounded-full hover:bg-green-dark transition-colors shadow-md whitespace-nowrap"
      >
        Subscribe
      </button>
    </form>
    <p class="text-xs text-slate-light mt-4">
      We respect your privacy. Unsubscribe at any time.
    </p>
  </div>
</section>
