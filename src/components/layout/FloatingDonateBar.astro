---
---

<div
  id="floating-donate"
  class="fixed bottom-0 left-0 right-0 z-40 translate-y-full transition-transform duration-500 ease-out"
>
  <div class="bg-gradient-to-r from-green-primary to-green-dark shadow-[0_-4px_30px_rgba(0,0,0,0.15)]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 flex items-center justify-between gap-4">
      <!-- Progress + Message -->
      <div class="flex items-center gap-4 flex-1 min-w-0">
        <!-- Mini progress bar -->
        <div class="hidden sm:flex items-center gap-3 shrink-0">
          <div class="w-28 h-2.5 bg-white/20 rounded-full overflow-hidden">
            <div class="h-full bg-amber-400 rounded-full" style="width: 40%"></div>
          </div>
          <span class="text-xs text-white/70 whitespace-nowrap font-medium">40% of goal</span>
        </div>
        <p class="text-sm text-white">
          <strong class="font-bold">This research can't continue without you.</strong>
          <span class="hidden md:inline"> Every dollar funds peer-reviewed science.</span>
        </p>
      </div>

      <!-- Actions -->
      <div class="flex items-center gap-2 shrink-0">
        <a
          href="/donate"
          class="inline-flex items-center px-6 py-2.5 bg-amber-400 text-slate-dark text-sm font-bold rounded-full hover:bg-amber-300 transition-colors shadow-md"
        >
          Donate Now
          <svg class="w-4 h-4 ml-1.5" viewBox="0 0 20 20" fill="currentColor">
            <path d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z" />
          </svg>
        </a>
        <button
          id="dismiss-donate-bar"
          class="p-1.5 text-white/40 hover:text-white/80 transition-colors rounded-lg"
          aria-label="Dismiss"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>
  </div>
</div>

<script>
  const bar = document.getElementById('floating-donate');
  const dismissBtn = document.getElementById('dismiss-donate-bar');
  const dismissed = sessionStorage.getItem('donate-bar-dismissed');

  if (!dismissed) {
    const observer = new IntersectionObserver(
      ([entry]) => {
        if (!entry.isIntersecting) {
          bar?.classList.remove('translate-y-full');
        }
      },
      { threshold: 0 }
    );

    // Show after scrolling past the first screen
    const hero = document.querySelector('[data-hero]') || document.querySelector('main > *:first-child');
    if (hero) observer.observe(hero);
  }

  dismissBtn?.addEventListener('click', () => {
    bar?.classList.add('translate-y-full');
    sessionStorage.setItem('donate-bar-dismissed', '1');
  });
</script>
