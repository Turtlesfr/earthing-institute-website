---
import { nav, site } from '../../data/config';

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 bg-cream/95 backdrop-blur-sm border-b border-cream-dark">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 lg:h-20">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-3 shrink-0">
        <div class="w-10 h-10 lg:w-12 lg:h-12 rounded-full bg-green-primary flex items-center justify-center">
          <svg viewBox="0 0 24 24" class="w-6 h-6 lg:w-7 lg:h-7 text-white" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M12 3c-1.5 3-5 6-5 10a5 5 0 0 0 10 0c0-4-3.5-7-5-10z" />
            <path d="M12 13v5" />
            <path d="M10 16l2-2 2 2" />
          </svg>
        </div>
        <div class="hidden sm:block">
          <div class="text-lg lg:text-xl font-heading font-bold text-green-primary leading-tight">The Earthing</div>
          <div class="text-lg lg:text-xl font-heading font-bold text-green-primary leading-tight -mt-1">Institute</div>
        </div>
      </a>

      <!-- Desktop Navigation -->
      <nav class="hidden lg:flex items-center gap-1">
        {nav.map((item) => (
          <div class="relative group">
            <a
              href={item.href}
              class:list={[
                'px-3 py-2 text-sm font-medium rounded-lg transition-colors',
                currentPath.startsWith(item.href)
                  ? 'text-green-primary bg-green-light'
                  : 'text-slate-dark hover:text-green-primary hover:bg-green-light/50',
              ]}
            >
              {item.label}
              {'children' in item && (
                <svg class="inline-block w-3 h-3 ml-0.5" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M3 5l3 3 3-3" />
                </svg>
              )}
            </a>
            {'children' in item && (
              <div class="absolute top-full left-0 pt-1 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200">
                <div class="bg-white rounded-xl shadow-lg border border-cream-dark p-2 min-w-48">
                  {item.children.map((child) => (
                    <a
                      href={child.href}
                      class="block px-3 py-2 text-sm text-slate-dark hover:text-green-primary hover:bg-green-light/50 rounded-lg transition-colors"
                    >
                      {child.label}
                    </a>
                  ))}
                </div>
              </div>
            )}
          </div>
        ))}
      </nav>

      <!-- Donate Button + Mobile Menu -->
      <div class="flex items-center gap-3">
        <a
          href="/donate"
          class="inline-flex items-center px-5 py-2.5 bg-green-primary text-white text-sm font-semibold rounded-full hover:bg-green-dark transition-colors shadow-md hover:shadow-lg"
        >
          Donate
          <svg class="w-4 h-4 ml-1.5" viewBox="0 0 20 20" fill="currentColor">
            <path d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z" />
          </svg>
        </a>

        <!-- Mobile menu button -->
        <button
          id="mobile-menu-btn"
          class="lg:hidden p-2 rounded-lg text-slate-dark hover:bg-green-light/50 transition-colors"
          aria-label="Open menu"
        >
          <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path id="menu-icon" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Navigation -->
  <div id="mobile-menu" class="lg:hidden hidden border-t border-cream-dark bg-cream">
    <div class="px-4 py-4 space-y-1">
      {nav.map((item) => (
        <div>
          <a
            href={item.href}
            class:list={[
              'block px-3 py-2.5 text-base font-medium rounded-lg transition-colors',
              currentPath.startsWith(item.href)
                ? 'text-green-primary bg-green-light'
                : 'text-slate-dark hover:text-green-primary hover:bg-green-light/50',
            ]}
          >
            {item.label}
          </a>
          {'children' in item && (
            <div class="ml-4 mt-1 space-y-1">
              {item.children.map((child) => (
                <a
                  href={child.href}
                  class="block px-3 py-2 text-sm text-slate hover:text-green-primary hover:bg-green-light/50 rounded-lg transition-colors"
                >
                  {child.label}
                </a>
              ))}
            </div>
          )}
        </div>
      ))}
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
